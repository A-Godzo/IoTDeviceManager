@model IEnumerable<IoTDeviceManager.Models.DeploymentSite>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<div class="card bg-light mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            
            <div class="col-md-5">
                <label class="form-label fw-bold">Search Site Name</label>
                <input type="text" name="siteName" value="@ViewData["CurrentSearch"]" class="form-control" placeholder="Type a site name..." />
            </div>
            
            <div class="col-md-4">
                <label class="form-label fw-bold">Status Filter</label>
                <select name="active" class="form-select">
                    <option value="">-- Show All Sites --</option>
                    <!option value="Active" @(ViewData["CurrentActiveFilter"]?.ToString() == "Active" ? "selected" : null)>Active Only</!option>
                    <!option value="Inactive" @(ViewData["CurrentActiveFilter"]?.ToString() == "Inactive" ? "selected" : null)>Inactive Only</!option>
                </select>
            </div>
            
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-secondary w-100">Filter</button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
            </div>
            
        </form>
    </div>
</div>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.SiteName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PhysicalAddress)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.NetworkSubnet)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IsActive)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.SiteName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PhysicalAddress)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.NetworkSubnet)
            </td>
            <td>
                @{
                    if (item.IsActive)
                    {
                        <span>Active</span>
                    }
                    else
                    {
                        <span>Inactive</span>
                    }
                }
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
