@model IoTDeviceManager.Models.Microcontroller

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Microcontroller for @ViewBag.siteName</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="CreateForSite">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="MACAddress" class="control-label"></label>
                <input asp-for="MACAddress" class="form-control" />
                <span asp-validation-for="MACAddress" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ChipModel" class="control-label"></label>
                <input asp-for="ChipModel" class="form-control" />
                <span asp-validation-for="ChipModel" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FirmwareVersion" class="control-label"></label>
                <input asp-for="FirmwareVersion" class="form-control" />
                <span asp-validation-for="FirmwareVersion" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="LastSeenAt" class="control-label"></label>
                <input asp-for="LastSeenAt" class="form-control" />
                <span asp-validation-for="LastSeenAt" class="text-danger"></span>
            </div>
            <input type="hidden" name="DeploymentSiteId" value="@ViewBag.siteId"/>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>