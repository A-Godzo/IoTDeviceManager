@model IoTDeviceManager.Models.DeviceConfiguration

@{
    ViewData["Title"] = "Attach Sensor Module";
}

<h2>Attach Sensor Module</h2>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @if (ViewData["IsContextual"] != null && (bool)ViewData["IsContextual"])
            {
                <div class="form-group mb-3">
                    <label class="form-label fw-bold text-muted">Target Microcontroller Unit</label>
                    <input type="text" class="form-control bg-light" value="@ViewData["TargetMcuName"]" readonly />
                    <input type="hidden" asp-for="MicrocontrollerId" value="@ViewData["TargetMcuId"]" />
                    <input type="hidden" name="fromMcu" value="true" />
                </div>
            }
            else
            {
                <div class="form-group mb-3">
                    <label asp-for="MicrocontrollerId" class="form-label fw-bold">Microcontroller MAC</label>
                    <select asp-for="MicrocontrollerId" class="form-control" asp-items="ViewBag.MicrocontrollerId"></select>
                </div>
            }

            <div class="form-group mb-3">
                <label asp-for="SensorModuleId" class="form-label fw-bold">Select Sensor Component</label>
                <select asp-for="SensorModuleId" class="form-control" asp-items="ViewBag.SensorModuleId"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DataPin" class="form-label fw-bold">Data Pin Allocation (e.g., GPIO 4, I2C 0x27)</label>
                <input asp-for="DataPin" class="form-control" placeholder="Enter connection pin mapping..." />
                <span asp-validation-for="DataPin" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">Lock Mapping & Deploy</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>